rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Clear run screenshots — pilotos suben, todos los autenticados leen
    match /clear-images/{clientId}/{bossId}/{filename} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
